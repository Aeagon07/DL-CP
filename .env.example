# =============================================================================
# Appian Operations Center — Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=appian
POSTGRES_PASSWORD=appian_secret
POSTGRES_DB=appian_ops
DATABASE_URL=postgresql://appian:appian_secret@localhost:5432/appian_ops

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_EVENTS=appian.events.raw
KAFKA_TOPIC_FEATURES=appian.features.computed
KAFKA_TOPIC_PREDICTIONS=appian.predictions.breach
KAFKA_TOPIC_ALERTS=appian.alerts.live
KAFKA_CONSUMER_GROUP=appian-feature-consumers
KAFKA_PRODUCER_ACKS=all
KAFKA_PRODUCER_RETRIES=3

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_FEATURE_TTL=3600        # Feature cache TTL in seconds (1 hour)
REDIS_SCENARIO_TTL=86400      # Scenario cache TTL (24 hours)

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=appian-breach-prediction
MLFLOW_MODEL_NAME=breach-classifier

# ── Model Configuration ───────────────────────────────────────────────────────
LSTM_SEQUENCE_LENGTH=12       # 12 x 5min = 60-minute rolling window
LSTM_HIDDEN_SIZE=128
LSTM_NUM_LAYERS=2
LSTM_DROPOUT=0.2
LSTM_LEARNING_RATE=0.001
LSTM_BATCH_SIZE=32
LSTM_EPOCHS=50

XGBOOST_MAX_DEPTH=6
XGBOOST_N_ESTIMATORS=300
XGBOOST_LEARNING_RATE=0.05
XGBOOST_SUBSAMPLE=0.8

BREACH_THRESHOLD=0.7          # Probability threshold for alert
DRIFT_THRESHOLD=0.05          # Page-Hinkley drift threshold

# ── Simulation ────────────────────────────────────────────────────────────────
MC_NUM_RUNS=1000
MC_NUM_WORKERS=4
SIMPY_SIM_DURATION_HOURS=8

# ── Data Generation ───────────────────────────────────────────────────────────
SYNTHETIC_NUM_QUEUES=6
SYNTHETIC_NUM_AGENTS=25
SYNTHETIC_DAYS=90
SYNTHETIC_INTERVAL_MINUTES=5

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000,http://localhost:5173
WS_METRICS_INTERVAL=5        # WebSocket metrics push every 5 seconds
WS_FORECAST_INTERVAL=30      # Forecast push every 30 seconds

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
